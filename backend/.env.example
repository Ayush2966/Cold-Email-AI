# MongoDB Atlas (free tier): Project → Connect → Drivers → copy connection string
# Replace <password> and set a database name (e.g. coldemail)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/coldemail?retryWrites=true&w=majority"

JWT_SECRET="change-me-in-production"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"
GEMINI_API_KEY=""
# Optional: default is gemini-2.5-flash (see https://ai.google.dev/gemini-api/docs/models/gemini)
# GEMINI_MODEL="gemini-2.5-flash"
PORT=4000
CORS_ORIGIN="http://localhost:5173"
